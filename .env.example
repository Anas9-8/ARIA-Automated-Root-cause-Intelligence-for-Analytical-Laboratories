# App settings
APP_NAME=ARIA
APP_VERSION=1.0.0
DEBUG=false

# Data paths
DATA_RAW_PATH=data/raw
DATA_PROCESSED_PATH=data/processed
DATA_SYNTHETIC_PATH=data/synthetic

# API settings
API_HOST=0.0.0.0
API_PORT=8000

# Dashboard settings
DASHBOARD_PORT=8501

# Database
DB_PATH=data/aria.db
